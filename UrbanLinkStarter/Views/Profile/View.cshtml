@model UrbanLinkStarter.Models.ApplicationUser
@{
    ViewData["Title"] = Model.FullName ?? Model.Email;
    var isSelf     = (bool)(ViewBag.IsSelf ?? false);
    var isAdmin    = (bool)(ViewBag.IsAdmin ?? false);
    var msgCount   = (int)(ViewBag.MessagesCount ?? 0);
    var tripsCount = (int)(ViewBag.TripsCount ?? 0);
    var name       = string.IsNullOrWhiteSpace(Model.FullName) ? (Model.Email ?? "User") : Model.FullName;

    string AvatarVariant()
    {
        var classes = new[] { "", "ul-avatar-violet", "ul-avatar-mint", "ul-avatar-sunset" };
        var idx = Math.Abs(Model.Id.GetHashCode()) % classes.Length;
        return classes[idx];
    }
    string Initials()
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
}

<section class="ul-detail-hero ul-enter" style="display:flex; gap:2rem; align-items:center; flex-wrap:wrap;">
    <div class="ul-profile-avatar-wrap @(isSelf ? "ul-profile-avatar-editable" : "")">
        <div class="ul-avatar @(string.IsNullOrEmpty(Model.ProfilePicture) ? AvatarVariant() : "")"
             style="width:96px; height:96px; font-size:2rem; overflow:hidden; padding:0; position:relative;">
            @if (!string.IsNullOrEmpty(Model.ProfilePicture))
            {
                <img src="@Model.ProfilePicture" alt="@name" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
            }
            else
            {
                @Initials()
            }
        </div>
        @if (isSelf)
        {
            <label class="ul-avatar-edit-btn" for="picInput" title="Change photo">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </label>
            <form method="post" asp-action="UploadPicture" enctype="multipart/form-data" id="picForm">
                @Html.AntiForgeryToken()
                <input type="file" id="picInput" name="picture" accept="image/*" style="display:none;" onchange="document.getElementById('picForm').submit();" />
            </form>
        }
    </div>

    <div style="flex:1; min-width: 220px;">
        <div class="ul-section-sub">@(isSelf ? "/ Your profile" : "/ Profile")</div>
        <h1 style="margin: 0.4rem 0 0.4rem;">
            @await Html.PartialAsync("_UserName", Model, new ViewDataDictionary(ViewData) { ["ulShowAge"] = true, ["ulIsAdmin"] = isAdmin })
        </h1>
        @if (Model.TotalRatings > 0) {
            <div style="margin-top:0.35rem; display:flex; align-items:center; gap:0.5rem;">
                <span style="color:var(--accent-amber);font-size:1.1rem;letter-spacing:0.05em;">@string.Concat(Enumerable.Repeat("★",(int)Math.Round(Model.AverageRating)))@string.Concat(Enumerable.Repeat("☆",5-(int)Math.Round(Model.AverageRating)))</span>
                <span style="font-family:var(--font-mono);font-size:0.82rem;color:var(--text-mid);">@Model.AverageRating.ToString("0.#") · @Model.TotalRatings review@(Model.TotalRatings==1?"":"")</span>
            </div>
        }
        @if (isSelf)
        {
            <div style="font-family: var(--font-mono); font-size: 0.86rem; color: var(--text-lo);">@Model.Email</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Bio))
        {
            <p style="margin-top: 1rem; max-width: 640px;">@Model.Bio</p>
        }
        else if (isSelf)
        {
            <p style="margin-top: 0.75rem; color: var(--text-lo); font-style: italic; font-size:0.95rem;">Add a bio so other riders know who you are.</p>
        }

        @if (isSelf)
        {
            <div style="margin-top: 1.25rem; display:flex; gap: 0.6rem; flex-wrap: wrap;">
                <a class="ul-btn ul-btn-secondary" asp-action="Edit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit profile
                </a>
                <a class="ul-btn ul-btn-secondary" asp-controller="Reservations" asp-action="Index">
                    🎟️ My reservations
                </a>
                @if (!Model.IsVerified)
                {
                    <a class="ul-btn ul-btn-primary" asp-controller="Verification" asp-action="Index">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c1.79 0 3.46.52 4.86 1.42"/></svg>
                        Get verified
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <form method="post" asp-action="RemovePicture" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ul-btn ul-btn-secondary" style="color: var(--accent-magenta);">Remove photo</button>
                    </form>
                }
            </div>
        }
    </div>
</section>

@if (TempData["Error"] != null)
{
    <div class="ul-auth-error ul-enter" style="margin-top:1rem;">@TempData["Error"]</div>
}

<div class="ul-grid ul-grid-3 ul-stagger" style="margin-top: 2rem;">
    @if (isSelf)
    {
        <a class="ul-card-link" asp-controller="Chat" asp-action="MyMessages">
            <div class="ul-stat">
                <div class="ul-stat-glow" style="background: var(--accent-mint);"></div>
                <div class="ul-stat-icon" style="background: var(--grad-mint);">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                </div>
                <div class="ul-stat-label">Chat posts</div>
                <div class="ul-stat-value">@msgCount</div>
            </div>
        </a>
    }
    else
    {
        <div class="ul-stat">
            <div class="ul-stat-glow" style="background: var(--accent-mint);"></div>
            <div class="ul-stat-icon" style="background: var(--grad-mint);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
            </div>
            <div class="ul-stat-label">Chat posts</div>
            <div class="ul-stat-value">@msgCount</div>
        </div>
    }

    <div class="ul-stat">
        <div class="ul-stat-glow" style="background: var(--accent-orange);"></div>
        <div class="ul-stat-icon" style="background: var(--grad-amber);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h2l1.5-4.5L9 6h6l2.5 6.5L19 17h2" /><circle cx="7" cy="17" r="2" /><circle cx="17" cy="17" r="2" /></svg>
        </div>
        <div class="ul-stat-label">Trips driven</div>
        <div class="ul-stat-value">@tripsCount</div>
    </div>

    <div class="ul-stat">
        <div class="ul-stat-glow" style="background: var(--accent-violet);"></div>
        <div class="ul-stat-icon" style="background: linear-gradient(135deg, var(--accent-violet), var(--accent-magenta));">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
        </div>
        <div class="ul-stat-label">Status</div>
        <div class="ul-stat-value" style="font-size: 1.4rem; padding-top: 0.5rem;">
            @if (Model.IsVerified)
            {
                <text>Verified</text>
            }
            else
            {
                <text>Member</text>
            }
        </div>
    </div>
</div>