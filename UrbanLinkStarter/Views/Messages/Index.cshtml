@{
    ViewData["Title"] = "Direct messages";
    var convos = ViewBag.Conversations as System.Collections.IEnumerable;

    string Initials(string? full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "U";
        var parts = full.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
    string Variant(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return "";
        var classes = new[] { "", "ul-avatar-violet", "ul-avatar-mint", "ul-avatar-sunset" };
        return classes[Math.Abs(key.GetHashCode()) % classes.Length];
    }
}

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ DMs</div>
        <h2>Direct Messages</h2>
    </div>
</div>

@{
    var any = false;
    if (convos != null)
    {
        foreach (var _ in convos) { any = true; break; }
    }
}

@if (any)
{
    <div class="ul-stagger" style="display:flex;flex-direction:column;gap:0.65rem;">
        @foreach (dynamic c in convos!)
        {
            var u = c.Other as UrbanLinkStarter.Models.ApplicationUser;
            var lm = c.LastMessage as UrbanLinkStarter.Models.DirectMessage;
            int unread = c.UnreadCount;
            <a class="ul-card" asp-action="Thread" asp-route-id="@u!.Id" style="display:flex;gap:1rem;align-items:center;text-decoration:none;padding:1rem;">
                <div class="ul-avatar @Variant(u.Id)" style="width:48px;height:48px;font-size:1rem;overflow:hidden;padding:0;flex-shrink:0;">
                    @if (!string.IsNullOrEmpty(u.ProfilePicture))
                    {
                        <img src="@u.ProfilePicture" alt="@u.FullName" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    }
                    else
                    {
                        @Initials(u.FullName)
                    }
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <strong style="color:var(--text-hi);">@u.FullName</strong>
                        @if (unread > 0)
                        {
                            <span class="ul-badge-dot" style="position:static;">@unread</span>
                        }
                    </div>
                    <div style="font-size:0.85rem;color:var(--text-mid);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:480px;">@lm!.Body</div>
                </div>
                <div style="font-size:0.78rem;color:var(--text-lo);white-space:nowrap;">@lm.SentOn.ToLocalTime().ToString("dd MMM, HH:mm")</div>
            </a>
        }
    </div>
}
else
{
    <div class="ul-card ul-enter" style="text-align:center;padding:2rem;">
        <p style="color:var(--text-mid);margin:0;">No conversations yet. Open a user's profile and click <strong>Message</strong>.</p>
    </div>
}
