@model UrbanLinkStarter.Models.ApplicationUser
@{
    ViewData["Title"] = Model.FullName ?? Model.Email;
    var messages = ViewBag.Messages as List<UrbanLinkStarter.Models.Message> ?? new();
    var isAdmin  = (bool)(ViewBag.IsAdmin ?? false);
    var name     = string.IsNullOrWhiteSpace(Model.FullName) ? (Model.Email ?? "User") : Model.FullName;

    string Initials(string? full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "U";
        var parts = full.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
    string AvatarVariant(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return "";
        var classes = new[] { "", "ul-avatar-violet", "ul-avatar-mint", "ul-avatar-sunset" };
        return classes[Math.Abs(key.GetHashCode()) % classes.Length];
    }
}

<a class="ul-trip-card-link ul-enter" asp-action="Users" style="margin-bottom: 1rem; display:inline-flex;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg);"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    All users
</a>

<section class="ul-detail-hero ul-enter" style="display:flex; gap:1.5rem; align-items:center; flex-wrap:wrap;">
    <div class="ul-avatar @(string.IsNullOrEmpty(Model.ProfilePicture) ? AvatarVariant(Model.Id) : "")"
         style="width:84px; height:84px; font-size:1.8rem; overflow:hidden; padding:0;">
        @if (!string.IsNullOrEmpty(Model.ProfilePicture))
        {
            <img src="@Model.ProfilePicture" alt="@name" style="width:100%; height:100%; object-fit:cover; border-radius:50%;" />
        }
        else
        {
            @Initials(name)
        }
    </div>

    <div style="flex:1; min-width: 220px;">
        <div class="ul-section-sub">/ Profile · Admin view</div>
        <h1 style="margin: 0.4rem 0 0.4rem;">
            @await Html.PartialAsync("_UserName", Model, new ViewDataDictionary(ViewData) { ["ulShowAge"] = true, ["ulIsAdmin"] = isAdmin })
        </h1>
        <div style="font-family: var(--font-mono); font-size: 0.86rem; color: var(--text-lo);">@Model.Email</div>
        @if (!string.IsNullOrWhiteSpace(Model.Bio))
        {
            <p style="margin-top: 1rem; max-width: 640px;">@Model.Bio</p>
        }
    </div>
</section>

<div class="ul-section-head" style="margin-top: 2.5rem;">
    <div>
        <div class="ul-section-sub">/ Activity</div>
        <h2>All messages</h2>
    </div>
    <span class="ul-pill ul-pill-cyan">@messages.Count total</span>
</div>

@if (messages.Any())
{
    <div class="ul-stagger">
    @foreach (var m in messages)
    {
        <div class="ul-message">
            <div class="ul-message-head">
                <div class="ul-avatar @AvatarVariant(m.UserId ?? name)" style="overflow:hidden; padding:0;">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="@Model.ProfilePicture" alt="@name" style="width:100%; height:100%; object-fit:cover; border-radius:50%;" />
                    }
                    else
                    {
                        @Initials(name)
                    }
                </div>
                <div>
                    <span class="ul-message-author">@name</span>
                    <div class="ul-message-time" style="margin-left:0;">
                        @m.CreatedOn.ToString("MMM d · HH:mm")
                        @if (m.EventId != null && m.Event != null)
                        {
                            <span style="margin-left: 0.4rem; color: var(--accent-mint);">· in event "@m.Event.Title"</span>
                        }
                        else
                        {
                            <span style="margin-left: 0.4rem; color: var(--text-lo);">· community chat</span>
                        }
                    </div>
                </div>
            </div>
            <div class="ul-message-body">@m.Content</div>
        </div>
    }
    </div>
}
else
{
    <div class="ul-empty ul-enter">
        <div class="ul-empty-icon">💬</div>
        <p>This user hasn't posted anything yet.</p>
    </div>
}
