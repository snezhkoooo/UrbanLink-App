@model IEnumerable<Trip>
@{
    ViewData["Title"] = "Manage trips";
}

<a class="ul-trip-card-link ul-enter" asp-action="Index" style="margin-bottom: 1rem; display:inline-flex;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg);"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    Dashboard
</a>

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Control room · Trips</div>
        <h2>Manage trips</h2>
    </div>
    <span class="ul-pill ul-pill-cyan">@Model.Count() total</span>
</div>

@if (Model.Any())
{
    <div class="ul-table-wrap ul-enter">
        <table class="ul-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Route</th>
                    <th>Date</th>
                    <th>Seats</th>
                    <th>Price</th>
                    <th>Event</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td class="ul-cell-strong">@t.Title</td>
                    <td class="ul-cell-route">@t.FromLocation <span class="arrow">→</span> @t.ToLocation</td>
                    <td>@t.TravelDate.ToString("MMM d · HH:mm")</td>
                    <td><span class="ul-pill ul-pill-cyan">@t.AvailableSeats</span></td>
                    <td><span class="ul-pill ul-pill-amber">@t.Price.ToString("0.##") €</span></td>
                    <td>
                        @if (t.Event != null)
                        {
                            <span style="font-size: 0.85rem; color: var(--accent-mint);">@t.Event.Title</span>
                        }
                        else
                        {
                            <span style="color: var(--text-lo); font-family: var(--font-mono); font-size: 0.78rem;">—</span>
                        }
                    </td>
                    <td>
                        <div class="ul-row-actions">
                            <a class="ul-row-action" asp-controller="Trips" asp-action="Details" asp-route-id="@t.Id" title="View details">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </a>
                            <a class="ul-row-action ul-row-action-edit" asp-action="EditTrip" asp-route-id="@t.Id" title="Edit">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                            <form method="post" asp-action="DeleteTrip" asp-route-id="@t.Id" style="margin:0;" data-confirm-msg="Delete this trip? This will remove its reservations.">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="ul-row-action ul-row-action-delete" title="Delete">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="ul-empty ul-enter">
        <div class="ul-empty-icon">🚗</div>
        <p>No trips on the board.</p>
    </div>
}
