@model IEnumerable<UrbanLinkStarter.Models.ApplicationUser>
@{
    ViewData["Title"] = "Users";
    var counts   = ViewBag.MessageCounts as Dictionary<string, int> ?? new();
    var adminIds = ViewBag.AdminUserIds as HashSet<string> ?? new();
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

    string Initials(string? full, string? email)
    {
        var s = string.IsNullOrWhiteSpace(full) ? email : full;
        if (string.IsNullOrWhiteSpace(s)) return "U";
        var parts = s.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
    string AvatarVariant(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return "";
        var classes = new[] { "", "ul-avatar-violet", "ul-avatar-mint", "ul-avatar-sunset" };
        return classes[Math.Abs(key.GetHashCode()) % classes.Length];
    }
}

<a class="ul-trip-card-link ul-enter" asp-action="Index" style="margin-bottom: 1rem; display:inline-flex;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg);"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    Dashboard
</a>

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Control room · Users</div>
        <h2>All users</h2>
    </div>
    <span class="ul-pill ul-pill-cyan">@Model.Count() total</span>
</div>

@if (TempData["Error"] != null)
{
    <div class="ul-auth-error ul-enter" style="margin-bottom:1rem;">@TempData["Error"]</div>
}

@if (Model.Any())
{
    <div class="ul-table-wrap ul-enter">
        <table class="ul-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Age</th>
                    <th>Messages</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                var name    = string.IsNullOrWhiteSpace(u.FullName) ? (u.Email ?? "") : u.FullName;
                var msgs    = counts.TryGetValue(u.Id, out var c) ? c : 0;
                var isSelf  = u.Id == currentUserId;
                var isAdmin = adminIds.Contains(u.Id);
                <tr>
                    <td>
                        <div style="display:flex; align-items:center; gap: 0.65rem;">
                            <div class="ul-avatar @AvatarVariant(u.Id)" style="width:34px;height:34px;font-size:0.78rem;overflow:hidden;padding:0;">
                                @if (!string.IsNullOrEmpty(u.ProfilePicture))
                                {
                                    <img src="@u.ProfilePicture" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"/>
                                }
                                else { @Initials(u.FullName, u.Email) }
                            </div>
                            <span class="ul-cell-strong">
                                @await Html.PartialAsync("_UserName", u, new ViewDataDictionary(ViewData) { ["ulShowAge"] = false, ["ulIsAdmin"] = isAdmin })
                            </span>
                        </div>
                    </td>
                    <td style="font-family: var(--font-mono); font-size: 0.82rem; color: var(--text-lo);">@u.Email</td>
                    <td><span class="ul-pill ul-pill-cyan">@u.Age</span></td>
                    <td><span class="ul-pill ul-pill-mint">@msgs</span></td>
                    <td>
                        <div class="ul-row-actions">
                            <a class="ul-row-action" asp-action="UserDetails" asp-route-id="@u.Id" title="View profile">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </a>
                            @if (!isSelf)
                            {
                                <form method="post" asp-action="DeleteUser" asp-route-id="@u.Id" style="margin:0;" data-confirm-msg="Permanently delete @name? This will remove all their messages and reservations.">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="ul-row-action ul-row-action-delete" title="Delete user">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="ul-empty ul-enter"><div class="ul-empty-icon">👤</div><p>No users yet.</p></div>
}
