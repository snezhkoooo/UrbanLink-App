@{
    ViewData["Title"] = "Admin";
    var pending = (int)(ViewBag.PendingVerifications ?? 0);
    var pendingDriver = (int)(ViewBag.PendingDriverVerifications ?? 0);
}

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Control room</div>
        <h2>Admin dashboard</h2>
    </div>
</div>

<div class="ul-grid ul-grid-4 ul-stagger">
    <a class="ul-card-link" asp-controller="Admin" asp-action="Users">
        <div class="ul-stat">
            <div class="ul-stat-glow" style="background: var(--accent-violet);"></div>
            <div class="ul-stat-icon" style="background: var(--grad-sunset);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="ul-stat-label">Users</div>
            <div class="ul-stat-value">@ViewBag.UsersCount</div>
        </div>
    </a>

    <a class="ul-card-link" asp-controller="Admin" asp-action="Trips">
        <div class="ul-stat">
            <div class="ul-stat-glow" style="background: var(--accent-orange);"></div>
            <div class="ul-stat-icon" style="background: var(--grad-amber);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h2l1.5-4.5L9 6h6l2.5 6.5L19 17h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            </div>
            <div class="ul-stat-label">Trips</div>
            <div class="ul-stat-value">@ViewBag.TripsCount</div>
        </div>
    </a>

    <a class="ul-card-link" asp-controller="Admin" asp-action="Events">
        <div class="ul-stat">
            <div class="ul-stat-glow" style="background: var(--accent-mint);"></div>
            <div class="ul-stat-icon" style="background: var(--grad-mint);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            </div>
            <div class="ul-stat-label">Events</div>
            <div class="ul-stat-value">@ViewBag.EventsCount</div>
        </div>
    </a>

    <a class="ul-card-link" asp-controller="Admin" asp-action="Chat">
        <div class="ul-stat">
            <div class="ul-stat-glow" style="background: var(--accent-cyan);"></div>
            <div class="ul-stat-icon" style="background: linear-gradient(135deg, var(--accent-cyan), var(--accent-violet));">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div class="ul-stat-label">Messages</div>
            <div class="ul-stat-value">@ViewBag.MessagesCount</div>
        </div>
    </a>
</div>

<div class="ul-section-head" style="margin-top: 2.5rem;">
    <div>
        <div class="ul-section-sub">/ Trust &amp; safety</div>
        <h2>Verifications</h2>
    </div>
    @if (pending > 0)
    {
        <span class="ul-pill ul-pill-amber">@pending pending</span>
    }
</div>

<div class="ul-grid ul-grid-2 ul-stagger" style="gap:1rem;">
    <a class="ul-card-link" asp-action="Verifications">
        <div class="ul-card" style="display:flex; align-items:center; gap:1rem; position:relative;">
            @if (pending > 0)
            {
                <span class="ul-badge-dot" style="top:8px;right:8px;">@pending</span>
            }
            <div style="width:48px; height:48px; border-radius:12px; background: linear-gradient(135deg, #58c8ff, #3b82f6); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
            <div style="flex:1; min-width:0;">
                <h3 class="ul-trip-card-title">Identity submissions</h3>
                <p style="margin:0.3rem 0 0; color: var(--text-mid); font-size: 0.92rem;">
                    @if (pending > 0) { <text>@pending pending — age/identity documents waiting for review.</text> }
                    else { <text>Approve or reject submitted IDs (age verification).</text> }
                </p>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
    </a>

    <a class="ul-card-link" asp-action="DriverVerifications">
        <div class="ul-card" style="display:flex; align-items:center; gap:1rem; position:relative;">
            @if (pendingDriver > 0)
            {
                <span class="ul-badge-dot" style="top:8px;right:8px;">@pendingDriver</span>
            }
            <div style="width:48px; height:48px; border-radius:12px; background: var(--grad-amber); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--bg-deep)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h2l1.5-4.5L9 6h6l2.5 6.5L19 17h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            </div>
            <div style="flex:1; min-width:0;">
                <h3 class="ul-trip-card-title">🚗 Driver submissions</h3>
                <p style="margin:0.3rem 0 0; color: var(--text-mid); font-size: 0.92rem;">
                    @if (pendingDriver > 0) { <text>@pendingDriver pending — car &amp; license photos waiting for review.</text> }
                    else { <text>Approve drivers to grant trip-posting + blue tick.</text> }
                </p>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
    </a>
</div>
