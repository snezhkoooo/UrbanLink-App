@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Legal</div>
        <h2>📄 Privacy Policy</h2>
    </div>
</section>

<div class="ul-card ul-enter" style="background:rgba(78,224,176,0.05);border-color:rgba(78,224,176,0.25);margin-bottom:1.25rem;">
    <strong style="color:var(--accent-mint);">ℹ Last updated:</strong>
    <span style="color:var(--text-mid);">May 2026</span>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>1. Who we are</h3>
    <p>UrbanLink is a student diploma project for facilitating ride-sharing and travel-event coordination in Bulgaria. The platform is operated for educational purposes.</p>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>2. What data we collect</h3>
    <ul style="color:var(--text-mid);line-height:1.7;">
        <li>Account information: full name, email, age, profile picture</li>
        <li>Identity verification documents (ID / passport / driver's license / proof of payment), stored only while a request is pending and wiped from the database after admin review</li>
        <li>Driver verification: car photos, driver's license photo, GDPR consent — kept until reviewed</li>
        <li>Trips, reservations, messages, and ratings you submit through the platform</li>
        <li>Technical data: IP address, browser, basic session cookies</li>
    </ul>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>3. How we use your data</h3>
    <ul style="color:var(--text-mid);line-height:1.7;">
        <li>To create and maintain your account and authenticate logins</li>
        <li>To verify your identity and driver status</li>
        <li>To match passengers with drivers and process reservations</li>
        <li>To moderate the platform and enforce the Terms of Use</li>
    </ul>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>4. Data sharing</h3>
    <p>Your name, age, profile photo, and verification badges are visible to other signed-in users. Identity-document images are visible only to administrators while a verification is pending. We do not sell or transfer your data to third parties.</p>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>5. Your rights (GDPR)</h3>
    <p>You may request access to, correction of, or deletion of your personal data at any time by contacting the administrators via the <a href="@Url.Action("Contacts","Home")" style="color:var(--accent-cyan);">Contacts</a> page. You may also withdraw consent for the storage of verification documents — doing so will revoke your verification badges.</p>
</div>

<div class="ul-card ul-enter" style="margin-bottom:1rem;">
    <h3>6. Cookies</h3>
    <p>We use only session and authentication cookies necessary for the site to function. We do not run analytics or advertising trackers.</p>
</div>

<div class="ul-card ul-enter">
    <h3>7. Contact</h3>
    <p>For privacy questions, contact <a href="mailto:nikolay.dyulgerov.highschool@buditel.bg" style="color:var(--accent-cyan);">nikolay.dyulgerov.highschool@buditel.bg</a>.</p>
</div>
