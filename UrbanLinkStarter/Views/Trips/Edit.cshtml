@model Trip
@{
    ViewData["Title"] = "Edit trip";
    var events = ViewBag.UpcomingEvents as List<Event> ?? new();
    var dateVal = Model.TravelDate.ToString("yyyy-MM-dd");
    var timeVal = Model.TravelDate.ToString("HH:mm");
}

<a class="ul-trip-card-link ul-enter" asp-action="Details" asp-route-id="@Model.Id" style="margin-bottom:1rem;display:inline-flex;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg)"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    Back to trip
</a>

<div class="ul-section-head ul-enter">
    <div><div class="ul-section-sub">/ Edit</div><h2>Edit trip</h2></div>
</div>

<form method="post" asp-route-id="@Model.Id" class="ul-form-card">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="ul-form-row">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" class="ul-input" />
    </div>

    <div class="ul-form-grid">
        <div class="ul-form-row">
            <label asp-for="FromLocation">From</label>
            <input asp-for="FromLocation" class="ul-input" data-place-suggest />
        </div>
        <div class="ul-form-row">
            <label asp-for="ToLocation">To</label>
            <input asp-for="ToLocation" class="ul-input" data-place-suggest />
        </div>
    </div>

    <div class="ul-form-row" style="margin-top:1.2rem;">
        <label>Date &amp; time</label>
        <div class="ul-wheel-row">
            <div class="ul-wheel-group">
                <div class="ul-wheel-label">Date</div>
                <div data-date-wheel data-target="eHidDate" data-value="@dateVal" data-combine-with="eTravelDate" data-time-input="eHidTime"></div>
            </div>
            <div class="ul-wheel-group">
                <div class="ul-wheel-label">Time (24h)</div>
                <div data-time-wheel data-target="eHidTime" data-value="@timeVal" data-combine-with="eTravelDate" data-date-input="eHidDate"></div>
            </div>
        </div>
        <input type="hidden" id="eHidDate" value="@dateVal" />
        <input type="hidden" id="eHidTime" value="@timeVal" />
        <input asp-for="TravelDate" type="hidden" id="eTravelDate" value="@(dateVal + "T" + timeVal)" />
    </div>

    <div class="ul-section-sub" style="margin-top:1.5rem;">/ Your car</div>

    <div class="ul-form-grid">
        <div class="ul-form-row">
            <label asp-for="CarBrand">Car brand</label>
            <input asp-for="CarBrand" class="ul-input" list="carBrandsList2" autocomplete="off" />
            <datalist id="carBrandsList2">
                <option value="Alfa Romeo"/><option value="Audi"/><option value="BMW"/>
                <option value="BYD"/><option value="Chevrolet"/><option value="Citroën"/>
                <option value="Dacia"/><option value="Fiat"/><option value="Ford"/>
                <option value="Honda"/><option value="Hyundai"/><option value="Kia"/>
                <option value="Land Rover"/><option value="Lexus"/><option value="Mazda"/>
                <option value="Mercedes-Benz"/><option value="Mini"/><option value="Mitsubishi"/>
                <option value="Nissan"/><option value="Opel"/><option value="Peugeot"/>
                <option value="Porsche"/><option value="Renault"/><option value="SEAT"/>
                <option value="Škoda"/><option value="Subaru"/><option value="Suzuki"/>
                <option value="Tesla"/><option value="Toyota"/><option value="Volvo"/>
                <option value="Volkswagen"/>
            </datalist>
        </div>
        <div class="ul-form-row">
            <label asp-for="CarModel">Model</label>
            <input asp-for="CarModel" class="ul-input" />
        </div>
    </div>

    <div class="ul-form-grid" style="margin-top:0.85rem;align-items:start;">
        <div class="ul-form-row">
            <label asp-for="CarYear">Year</label>
            <div data-year-wheel data-target="eCarYear" data-value="@Model.CarYear" data-min="1980" data-max="@DateTime.Now.Year"></div>
            <input asp-for="CarYear" type="hidden" id="eCarYear" value="@Model.CarYear" />
        </div>
        <div>
            <div class="ul-form-row">
                <label asp-for="FuelType">Fuel</label>
                <select asp-for="FuelType" class="ul-input" style="cursor:pointer;">
                    <option value="0">Gasoline</option>
                    <option value="1">Diesel</option>
                    <option value="2">LPG</option>
                    <option value="3">Electric</option>
                </select>
            </div>
            <div class="ul-form-row" style="margin-top:0.85rem;">
                <label asp-for="FuelConsumption">Consumption (L/100km)</label>
                <input asp-for="FuelConsumption" type="number" step="0.1" min="1" max="30" class="ul-input" />
            </div>
        </div>
    </div>

    <div class="ul-form-row" style="margin-top:1.2rem;">
        <label asp-for="AvailableSeats">Available seats</label>
        <div class="ul-seats" id="editSeatsPicker">
            @for (int i = 1; i <= 6; i++) {
                <button type="button" class="ul-seat-btn @(Model.AvailableSeats==i?"active":"")" data-seats="@i">@i</button>
            }
        </div>
        <input asp-for="AvailableSeats" type="hidden" id="editSeatsInput" value="@Model.AvailableSeats" />
    </div>

    @if (events.Any())
    {
        <div class="ul-form-row" style="margin-top:1.5rem;" id="editEventPicker">
            <label>Linked event <span style="color:var(--text-lo);font-weight:500;text-transform:none;letter-spacing:0;">(optional)</span></label>
            <div class="ul-event-picker">
                <div class="ul-event-pick @(Model.EventId==null?"active":"")" data-event-id="" tabindex="0" role="button">
                    <div class="ul-event-pick-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg></div>
                    <div class="ul-event-pick-body"><div class="ul-event-pick-title">No event</div><div class="ul-event-pick-meta">Standalone trip</div></div>
                </div>
                @foreach (var ev in events) {
                    <div class="ul-event-pick @(Model.EventId==ev.Id?"active":"")" data-event-id="@ev.Id" tabindex="0" role="button">
                        <div class="ul-event-pick-icon ul-event-pick-icon-amber">
                            <span class="ul-event-pick-day">@ev.EventDate.ToString("dd")</span>
                            <span class="ul-event-pick-month">@ev.EventDate.ToString("MMM").ToUpper()</span>
                        </div>
                        <div class="ul-event-pick-body">
                            <div class="ul-event-pick-title">@ev.Title</div>
                            <div class="ul-event-pick-meta">@ev.Location · @ev.EventDate.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            </div>
            <input type="hidden" name="EventId" id="editEventIdInput" value="@(Model.EventId?.ToString() ?? "")" />
        </div>
    } else {
        <input type="hidden" name="EventId" value="" />
    }

    <div style="display:flex;gap:0.75rem;margin-top:1.75rem;">
        <button type="submit" class="ul-btn ul-btn-success">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            Save changes
        </button>
        <a class="ul-btn ul-btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </div>
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    var d=document.getElementById('eHidDate'), t=document.getElementById('eHidTime'), h=document.getElementById('eTravelDate');
    function sync(){ if(d.value&&t.value) h.value=d.value+'T'+t.value; }
    d.addEventListener('change',sync); t.addEventListener('change',sync);

    var sp=document.getElementById('editSeatsPicker'), si=document.getElementById('editSeatsInput');
    sp.addEventListener('click',function(e){ var b=e.target.closest('.ul-seat-btn'); if(!b) return; e.preventDefault(); si.value=b.dataset.seats; sp.querySelectorAll('.ul-seat-btn').forEach(function(x){x.classList.toggle('active',x===b);}); });

    var ep=document.getElementById('editEventPicker');
    if(ep){ ep.addEventListener('click',function(e){ var item=e.target.closest('.ul-event-pick'); if(!item) return; document.getElementById('editEventIdInput').value=item.dataset.eventId||''; ep.querySelectorAll('.ul-event-pick').forEach(function(x){x.classList.remove('active');}); item.classList.add('active'); }); }
});
</script>
}
