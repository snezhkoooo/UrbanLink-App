@model IEnumerable<Trip>
@{
    ViewData["Title"] = "My trips";

    string Initials(string? full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "U";
        var parts = full.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
    string AvatarVariant(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return "";
        var classes = new[] { "", "ul-avatar-violet", "ul-avatar-mint", "ul-avatar-sunset" };
        return classes[Math.Abs(key.GetHashCode()) % classes.Length];
    }
    string PayLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash         => "💵 Cash",
        PaymentMethod.Revolut      => "📱 Revolut",
        PaymentMethod.BankTransfer => "🏦 Bank",
        _ => m.ToString()
    };
}

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Your listings</div>
        <h2>My trips</h2>
    </div>
    <a class="ul-btn ul-btn-primary" asp-controller="Trips" asp-action="Create">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        Post a trip
    </a>
</div>

@if (Model.Any())
{
    <div class="ul-grid ul-stagger" style="gap: 1.25rem;">
    @foreach (var trip in Model)
    {
        var seatsUsed = trip.Reservations.Sum(r => r.SeatsCount);
        var seatsLeft = trip.AvailableSeats - seatsUsed;
        <article class="ul-card">
            <div class="ul-trip-card-head" style="margin-bottom: 0.75rem;">
                <h3 class="ul-trip-card-title">@trip.Title</h3>
                <span class="ul-trip-card-price">@trip.Price.ToString("0.##") BGN</span>
            </div>

            <div class="ul-route" style="margin-bottom: 0.85rem;">
                <div class="ul-route-stop">
                    <div class="ul-route-stop-label">From</div>
                    <div class="ul-route-stop-name">@trip.FromLocation</div>
                </div>
                <div class="ul-route-line"></div>
                <div class="ul-route-stop" style="text-align:right;">
                    <div class="ul-route-stop-label">To</div>
                    <div class="ul-route-stop-name">@trip.ToLocation</div>
                </div>
            </div>

            <div class="ul-trip-meta" style="margin-bottom: 1rem;">
                <span class="ul-trip-meta-item">📅 @trip.TravelDate.ToString("ddd, MMM d · HH:mm")</span>
                <span class="ul-trip-meta-item @(seatsLeft <= 0 ? "style=\"color:var(--accent-magenta)\"" : "")">
                    👥 @seatsUsed / @trip.AvailableSeats seats booked
                </span>
                @if (trip.Event != null)
                {
                    <span class="ul-trip-meta-item" style="color: var(--accent-mint);">🎫 @trip.Event.Title</span>
                }
            </div>

            @if (trip.Reservations.Any())
            {
                <div style="background: rgba(0,0,0,0.2); border-radius: 12px; overflow: hidden; border: 1px solid var(--border);">
                    @foreach (var r in trip.Reservations)
                    {
                        var u    = r.User;
                        var name = u?.FullName ?? u?.Email ?? "Unknown";
                        var variant = AvatarVariant(r.UserId);

                        <div style="display:flex; align-items:center; gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border);">
                            <div class="ul-avatar @variant" style="width:32px; height:32px; font-size:0.75rem; overflow:hidden; padding:0; flex-shrink:0;">
                                @if (u != null && !string.IsNullOrEmpty(u.ProfilePicture))
                                {
                                    <img src="@u.ProfilePicture" alt="@name" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"/>
                                }
                                else { @Initials(name) }
                            </div>
                            <div style="flex:1; min-width:0;">
                                <a asp-controller="Profile" asp-action="View" asp-route-id="@r.UserId" style="text-decoration:none;">
                                    <span style="font-weight:600; color: var(--text-hi);">@name</span>
                                </a>
                                @if (u != null && u.Age >= 18)
                                {
                                    <span class="ul-age-tag">· @u.Age</span>
                                }
                                @if (u != null && u.IsVerified)
                                {
                                    <span class="ul-badge ul-badge-verified" title="Verified"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
                                }
                            </div>
                            <span class="ul-pill ul-pill-cyan" style="font-size:0.78rem;">@r.SeatsCount seat@(r.SeatsCount > 1 ? "s" : "")</span>
                            <span class="ul-pill" style="background:rgba(78,224,176,0.1);color:var(--accent-mint);border:1px solid rgba(78,224,176,0.25);font-size:0.78rem;">@PayLabel(r.PaymentMethod)</span>
                        </div>
                    }
                    @if (trip.Reservations.Count == 0 || trip.Reservations.Last().Id == trip.Reservations.Last().Id)
                    {
                        @* Remove last border via CSS :last-child *@
                    }
                </div>
            }
            else
            {
                <div style="text-align:center; padding: 1rem; color: var(--text-lo); font-style:italic; font-size:0.9rem;">No reservations yet.</div>
            }

            <div style="margin-top: 0.85rem; display:flex; gap: 0.5rem;">
                <a class="ul-btn ul-btn-secondary ul-btn-sm" asp-controller="Trips" asp-action="Details" asp-route-id="@trip.Id">View trip</a>
            </div>
        </article>
    }
    </div>
}
else
{
    <div class="ul-empty ul-enter">
        <div class="ul-empty-icon">🚗</div>
        <p>You haven't posted any trips yet. <a asp-controller="Trips" asp-action="Create" style="color: var(--accent-mint);">Post your first one.</a></p>
    </div>
}
