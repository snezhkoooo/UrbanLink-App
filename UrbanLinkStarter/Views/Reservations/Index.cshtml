@model IEnumerable<Reservation>
@{
    ViewData["Title"] = "My reservations";

    string PayLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash => "💵 Cash",
        PaymentMethod.Revolut => "📱 Revolut",
        PaymentMethod.BankTransfer => "🏦 Bank transfer",
        _ => m.ToString()
    };
}

<div class="ul-section-head ul-enter">
    <div>
        <div class="ul-section-sub">/ Your trips</div>
        <h2>My reservations</h2>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ul-card ul-enter" style="border-color: rgba(78,224,176,0.4); background: rgba(78,224,176,0.05); margin-bottom:1rem;">
        <p style="margin:0; color: var(--accent-mint);">@TempData["Success"]</p>
    </div>
}

@if (Model.Any())
{
    <div class="ul-grid ul-stagger" style="gap: 1rem;">
    @foreach (var r in Model)
    {
        var trip = r.Trip!;
        <article class="ul-card ul-trip-card">
            <div class="ul-trip-card-head">
                <h3 class="ul-trip-card-title">@trip.Title</h3>
                <span class="ul-trip-card-price">@trip.Price.ToString("0.##") BGN</span>
            </div>
            <div class="ul-route">
                <div class="ul-route-stop">
                    <div class="ul-route-stop-label">From</div>
                    <div class="ul-route-stop-name">@trip.FromLocation</div>
                </div>
                <div class="ul-route-line"></div>
                <div class="ul-route-stop" style="text-align:right;">
                    <div class="ul-route-stop-label">To</div>
                    <div class="ul-route-stop-name">@trip.ToLocation</div>
                </div>
            </div>
            <div class="ul-trip-meta">
                <span class="ul-trip-meta-item">📅 @trip.TravelDate.ToString("ddd, MMM d · HH:mm")</span>
                <span class="ul-trip-meta-item">@PayLabel(r.PaymentMethod)</span>
            </div>
            <div style="display:flex; gap:0.5rem; margin-top: 0.5rem;">
                <a class="ul-btn ul-btn-secondary ul-btn-sm" asp-controller="Trips" asp-action="Details" asp-route-id="@trip.Id">View trip</a>
                <form method="post" asp-action="Cancel" asp-route-id="@r.Id" style="margin:0;" data-confirm-msg="Cancel this reservation?">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="ul-btn ul-btn-secondary ul-btn-sm" style="color: var(--accent-magenta);">Cancel</button>
                </form>
            </div>
        </article>
    }
    </div>
}
else
{
    <div class="ul-empty ul-enter">
        <div class="ul-empty-icon">🎟️</div>
        <p>No reservations yet. Browse <a asp-controller="Trips" asp-action="Index" style="color: var(--accent-mint);">upcoming trips</a> to book a seat.</p>
    </div>
}
