@* Renders: "Jane Doe · 27 ★4.8 [✓ blue] [✓ red]"
   Keys: ulShowAge (bool), ulIsAdmin (bool)
*@
@model UrbanLinkStarter.Models.ApplicationUser
@{
    var showAge = ViewData["ulShowAge"] is bool sa ? sa : true;
    var isAdm   = ViewData["ulIsAdmin"] is bool ia ? ia : false;
    var name    = string.IsNullOrWhiteSpace(Model.FullName) ? (Model.Email ?? "User") : Model.FullName;
}
<span class="ul-name-line">
    <span class="ul-name-text">@name</span>
    @if (showAge && Model.Age >= 18)
    {
        <span class="ul-age-tag">· @Model.Age</span>
    }
    @if (Model.TotalRatings > 0)
    {
        <span class="ul-rating-tag" title="@Model.TotalRatings rating@(Model.TotalRatings == 1 ? "" : "s")">
            ★ @Model.AverageRating.ToString("0.#")
        </span>
    }
    @if (Model.IsDriver)
    {
        <span class="ul-badge ul-badge-verified" title="Verified driver">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
    }
    @if (isAdm)
    {
        <span class="ul-badge ul-badge-admin" title="UrbanLink admin">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
    }
</span>
