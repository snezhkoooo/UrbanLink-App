@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
    var providers = Model.ExternalLogins.Select(s => s.Name.ToLower()).ToHashSet();

    // Show ALL provider buttons. If a provider isn't configured server-side, the button posts to a dummy
    // route that surfaces a friendly "Provider X is not yet configured" message via TempData.
    var allProviders = new[]
    {
        new { Key = "Google",    Class = "ul-oauth-google",    Label = "Continue with Google" },
        new { Key = "Apple",     Class = "ul-oauth-apple",     Label = "Continue with Apple" },
        new { Key = "Facebook",  Class = "ul-oauth-facebook",  Label = "Continue with Facebook" },
        new { Key = "Instagram", Class = "ul-oauth-instagram", Label = "Continue with Instagram" },
        new { Key = "Twitter",   Class = "ul-oauth-x",         Label = "Continue with X" }
    };
}

<div class="ul-auth-wrap">
    <div class="ul-auth-card ul-enter">
        <div class="ul-section-sub">/ Welcome back</div>
        <h2 style="margin-top: 0.4rem;">Sign in</h2>
        <p style="margin-top: 0.4rem; margin-bottom: 1.5rem; color: var(--text-mid);">Pick up where you left off.</p>

        @if (TempData["Error"] != null)
        {
            <div class="ul-auth-error">@TempData["Error"]</div>
        }

        <div class="ul-oauth-row">
            @foreach (var p in allProviders)
            {
                var isConfigured = providers.Contains(p.Key.ToLower());
                if (isConfigured)
                {
                    <form method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" style="margin:0;">
                        <button type="submit" name="provider" value="@p.Key" class="ul-oauth-btn @p.Class" title="@p.Label">
                            @await Html.PartialAsync("_OAuthIcon", p.Key)
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" class="ul-oauth-btn @p.Class ul-oauth-disabled" title="@p.Label · not configured" onclick="alert('@p.Key sign-in is not configured yet.\nAdd keys in appsettings.json under Authentication.@p.Key and restart.');">
                        @await Html.PartialAsync("_OAuthIcon", p.Key)
                    </button>
                }
            }
        </div>

        <div class="ul-divider"><span>or with email</span></div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="ul-auth-error"></div>

            <div class="ul-form-row">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="ul-input" placeholder="you@urbanlink.local" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="ul-field-error"></span>
            </div>

            <div class="ul-form-row">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="ul-input" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="ul-field-error"></span>
            </div>

            <label class="ul-checkbox">
                <input asp-for="Input.RememberMe" />
                <span>Keep me signed in</span>
            </label>

            <button type="submit" class="ul-btn ul-btn-primary" style="width: 100%; justify-content: center; margin-top: 1.25rem;">
                Sign in
                <svg class="ul-btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>

            <p class="ul-auth-foot">
                New here? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
            </p>
        </form>
    </div>
</div>
